//@version=6
strategy("Glass Box CSP — BTC/TSLA", overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=2,
     pyramiding=0,
     calc_on_every_tick=false,
     process_orders_on_close=true)

// REPLACE <USERNAME> with your TradingView handle after publishing the library script.
// Example:  import johndoe/AtrMeanReversion/1 as amr
import <USERNAME>/AtrMeanReversion/1 as amr

// ─────────────────────────────────────────────────────────────────────────────
// Inputs
// ─────────────────────────────────────────────────────────────────────────────
g_strat = "Strategy Parameters"
bb_length    = input.int(20,   "BB Length",       group=g_strat)
bb_mult      = input.float(2.0,"BB Mult",         group=g_strat, step=0.1)
bb_pct_entry = input.float(0.20,"BB %B Entry <",  group=g_strat, minval=0, maxval=1, step=0.01)
bb_pct_exit  = input.float(0.50,"BB %B Exit >",   group=g_strat, minval=0, maxval=1, step=0.01)
sma_length   = input.int(200,  "Long SMA Length", group=g_strat)

g_atr = "ATR Trailing Stop"
atr_length = input.int(14,   "ATR Length", group=g_atr)
atr_mult   = input.float(2.0,"ATR Mult",   group=g_atr, step=0.1)

g_reg = "Regime Filter"
hurst_length    = input.int(100,   "Hurst Window",      group=g_reg)
hurst_threshold = input.float(0.45,"Hurst Threshold",   group=g_reg, minval=0, maxval=1, step=0.01)

g_opt = "Options Parameters (webhook payload only — Pine cannot trade options)"
delta_target = input.float(0.20,"Delta Target", group=g_opt, minval=0, maxval=1, step=0.05)
dte          = input.int(30,    "DTE",          group=g_opt)

g_wh = "Webhook"
webhook_enabled = input.bool(true, "Enable Slack webhook alerts", group=g_wh)

// ─────────────────────────────────────────────────────────────────────────────
// Calculations
// ─────────────────────────────────────────────────────────────────────────────
[bb_upper, bb_lower, bb_pct] = amr.bollinger_bands(bb_length, bb_mult, close)
sma_long   = ta.sma(close, sma_length)
trail_stop = amr.atr_trailing_stop(atr_length, atr_mult)
hurst_val  = amr.hurst_rs(hurst_length)
regime     = amr.regime_label(hurst_val, hurst_threshold, 1 - hurst_threshold)
atr_val    = ta.atr(atr_length)

// 0.20-delta put ≈ 1.5 × σ × √T OTM. ATR/close is a crude realised-vol proxy;
// the precise BS pricing lives in the Python research stack.
strike_hint = close * (1 - (atr_val / close) * math.sqrt(dte / 365.0) * 1.5)

// ─────────────────────────────────────────────────────────────────────────────
// Signals
// ─────────────────────────────────────────────────────────────────────────────
entry_signal = bb_pct < bb_pct_entry
     and close > sma_long
     and hurst_val < hurst_threshold
     and not na(hurst_val)
     and strategy.position_size == 0

in_pos = strategy.position_size > 0
exit_take_profit = in_pos and bb_pct > bb_pct_exit
exit_trend_break = in_pos and close < sma_long
exit_stop        = in_pos and close < trail_stop
exit_any         = exit_take_profit or exit_trend_break or exit_stop

// ─────────────────────────────────────────────────────────────────────────────
// Orders
// ─────────────────────────────────────────────────────────────────────────────
if entry_signal
    strategy.entry("CSP_LONG", strategy.long)

if exit_any
    strategy.close("CSP_LONG", comment = exit_take_profit ? "TP" : exit_trend_break ? "TREND" : "STOP")

// ─────────────────────────────────────────────────────────────────────────────
// Slack webhook payloads (Block Kit)
// ─────────────────────────────────────────────────────────────────────────────
alert_msg = '{"text":"🔔 SELL_PUT — ' + syminfo.ticker + '",' +
     '"blocks":[' +
     '{"type":"header","text":{"type":"plain_text","text":"📉 Sell Cash-Secured Put — ' + syminfo.ticker + '"}},' +
     '{"type":"section","fields":[' +
         '{"type":"mrkdwn","text":"*Action:*\nSELL_PUT"},' +
         '{"type":"mrkdwn","text":"*Symbol:*\n' + syminfo.ticker + '"},' +
         '{"type":"mrkdwn","text":"*Strike Hint:*\n$' + str.tostring(strike_hint, "#.##") + '"},' +
         '{"type":"mrkdwn","text":"*DTE:*\n' + str.tostring(dte) + ' days"},' +
         '{"type":"mrkdwn","text":"*Delta Target:*\n' + str.tostring(delta_target, "#.##") + '"},' +
         '{"type":"mrkdwn","text":"*Spot:*\n$' + str.tostring(close, "#.##") + '"},' +
         '{"type":"mrkdwn","text":"*ATR:*\n$' + str.tostring(atr_val, "#.##") + '"},' +
         '{"type":"mrkdwn","text":"*Regime:*\n' + regime + '"},' +
         '{"type":"mrkdwn","text":"*Hurst:*\n' + str.tostring(hurst_val, "#.##") + '"},' +
         '{"type":"mrkdwn","text":"*BB %B:*\n' + str.tostring(bb_pct, "#.##") + '"}' +
     ']},' +
     '{"type":"context","elements":[' +
         '{"type":"mrkdwn","text":"Bar time: ' + str.format_time(time, "yyyy-MM-dd HH:mm 'UTC'", "UTC") + ' | Strategy: Glass Box CSP"}' +
     ']}' +
     ']}'

if entry_signal and webhook_enabled
    alert(alert_msg, alert.freq_once_per_bar_close)

exit_msg = '{"text":"✅ CLOSE position — ' + syminfo.ticker + ' @ $' + str.tostring(close, "#.##") + '"}'
if exit_any and webhook_enabled
    alert(exit_msg, alert.freq_once_per_bar_close)

// ─────────────────────────────────────────────────────────────────────────────
// Plots
// ─────────────────────────────────────────────────────────────────────────────
plot(bb_upper, "BB Upper", color=color.new(color.teal, 70))
plot(bb_lower, "BB Lower", color=color.new(color.teal, 70))
plot(sma_long, "SMA 200",  color=color.new(color.orange, 0), linewidth=2)
plot(in_pos ? trail_stop : na, "ATR Trail Stop", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=2)
bgcolor(in_pos ? color.new(color.green, 90) : na, title="In Position")

// HUD: regime + Hurst readout in the bottom-right corner.
var table hud = table.new(position.bottom_right, 2, 2, border_width=1)
if barstate.islast
    table.cell(hud, 0, 0, "R/S Hurst", text_color=color.white, bgcolor=color.new(color.black, 30))
    table.cell(hud, 1, 0, na(hurst_val) ? "n/a" : str.tostring(hurst_val, "#.##"),
         text_color=color.white, bgcolor=color.new(color.black, 30))
    table.cell(hud, 0, 1, "Regime", text_color=color.white, bgcolor=color.new(color.black, 30))
    reg_color = regime == "MEAN_REVERTING" ? color.new(color.green, 20) :
         regime == "TRENDING" ? color.new(color.red, 20) : color.new(color.gray, 20)
    table.cell(hud, 1, 1, regime, text_color=color.white, bgcolor=reg_color)
