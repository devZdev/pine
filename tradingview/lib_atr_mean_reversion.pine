//@version=6
// AtrMeanReversion — math primitives for the Glass Box CSP strategy.
// R/S Hurst is used here (single-window, fast). The offline Python research
// stack uses DFA, which is more robust but too heavy for tick-by-tick Pine.
library("AtrMeanReversion", overlay=true)

// @function   Wilder ATR-based trailing stop that only ratchets upward.
//             Designed for long underlying exposure (selling puts = synthetic long).
// @param      length     ATR lookback (Wilder).
// @param      multiplier ATR multiple subtracted from price.
// @returns    Series float — monotonically non-decreasing trailing stop level.
export atr_trailing_stop(simple int length, simple float multiplier) =>
    atr_val = ta.atr(length)
    raw_stop = close - multiplier * atr_val
    // Ratchet: stop never moves down once established.
    var float trail = na
    trail := na(trail) ? raw_stop : math.max(trail, raw_stop)
    trail

// @function   Bollinger bands with %B normalisation.
// @param      length Lookback for SMA / stdev.
// @param      mult   Standard-deviation multiplier.
// @param      src    Source series (typically close).
// @returns    Tuple [upper, lower, percent_b].
export bollinger_bands(simple int length, simple float mult, series float src) =>
    mid = ta.sma(src, length)
    dev = ta.stdev(src, length)
    upper = mid + mult * dev
    lower = mid - mult * dev
    percent_b = (src - lower) / (upper - lower)
    [upper, lower, percent_b]

// @function   R/S (rescaled range) Hurst exponent over a single window.
//             H < 0.5 → mean-reverting; H ≈ 0.5 → random walk; H > 0.5 → trending.
//             Returns na if length < 20 (statistically meaningless).
// @param      length Window size in bars.
// @returns    Series float — estimated Hurst exponent for the trailing window.
export hurst_rs(simple int length) =>
    float result = na
    if length >= 20 and bar_index >= length
        // Build log-return series for the trailing window.
        rets = array.new<float>(0)
        for i = 0 to length - 1
            p1 = close[i]
            p0 = close[i + 1]
            if not na(p1) and not na(p0) and p0 > 0 and p1 > 0
                array.push(rets, math.log(p1 / p0))
        n = array.size(rets)
        if n >= 20
            mean_r = array.avg(rets)
            // Mean-adjusted cumulative deviation series Z.
            cum = 0.0
            zmin = 0.0
            zmax = 0.0
            sum_sq = 0.0
            for i = 0 to n - 1
                d = array.get(rets, i) - mean_r
                cum += d
                zmin := i == 0 ? cum : math.min(zmin, cum)
                zmax := i == 0 ? cum : math.max(zmax, cum)
                sum_sq += d * d
            r = zmax - zmin
            s = math.sqrt(sum_sq / n)
            if s > 0 and r > 0
                result := math.log(r / s) / math.log(n)
    result

// @function   Map a Hurst value to a regime label.
// @param      hurst            Hurst exponent.
// @param      threshold_lower  Below → MEAN_REVERTING (default 0.45).
// @param      threshold_upper  Above → TRENDING (default 0.55).
// @returns    "MEAN_REVERTING" | "TRENDING" | "NEUTRAL".
export regime_label(series float hurst, simple float threshold_lower, simple float threshold_upper) =>
    na(hurst) ? "NEUTRAL" :
       hurst < threshold_lower ? "MEAN_REVERTING" :
       hurst > threshold_upper ? "TRENDING" : "NEUTRAL"
