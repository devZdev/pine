# ── Coinbase Advanced Trade API ──────────────────────────────────────────────
# Generate at: https://www.coinbase.com/settings/api
# Format: organizations/<org-id>/apiKeys/<key-id>
COINBASE_API_KEY=YOUR_COINBASE_API_KEY_HERE
COINBASE_API_SECRET=YOUR_COINBASE_API_SECRET_HERE

# ── Alpaca Markets ────────────────────────────────────────────────────────────
# Generate at: https://alpaca.markets (paper trading account, free)
# Key format:  PKXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_API_KEY=YOUR_ALPACA_API_KEY_HERE
ALPACA_SECRET_KEY=YOUR_ALPACA_SECRET_KEY_HERE

# ── Hugging Face ──────────────────────────────────────────────────────────────
# Required for Phase 2 (Black Box engine — Chronos-T5 / TimesFM)
# Generate at: https://huggingface.co/settings/tokens  (free account)
HUGGINGFACE_TOKEN=YOUR_HUGGINGFACE_TOKEN_HERE

# ── Webhook (Phase 4 — TradingView alerts) ───────────────────────────────────
# The secret added to TradingView alert webhook URL for payload verification
WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE
